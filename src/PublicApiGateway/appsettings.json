{
  "ConnectionStrings": {
    "Redis": "localhost:6379",
    "PostgreSQL": "Host=localhost;Port=5432;Database=pluginruntime;Username=postgres;Password=postgres"
  },
  "Gateway": {
    "CacheTtlSeconds": 300,
    "MaxRequestBodyBytes": 10485760,
    "MaxRequestHeaderBytes": 8192,
    "UsageBufferCapacity": 10000,
    "IpBlockThreshold": 10,
    "IpBlockWindowSeconds": 60,
    "IpBlockDurationSeconds": 300,
    "ApiKeyPattern": "^[a-zA-Z0-9\\-_]{32,128}$"
  },
  "Upstream": {
    "BaseUrl": "http://localhost:5000",
    "TimeoutSeconds": 30,
    "MaxTimeoutSeconds": 300
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
