{
  "extension_id": "system.auth",
  "version": "1.0.0",
  "name": "Authentication Service",
  "description": "System extension providing user registration, login, and JWT token issuance.",
  "author": "Plugin Runtime Platform",
  "entry_point": "System.Auth.dll",
  "entry_class": "System.Auth.AuthPlugin",
  "type": "system",
  "capabilities": ["database"],
  "permissions": [
    {
      "capability": "database",
      "scope": "read_write",
      "justification": "Stores and retrieves user accounts for authentication"
    }
  ],
  "visibility": "public",
  "is_system": true,
  "skip_signature_verification": true,
  "routes": [
    { "method": "POST", "path": "/api/auth/register", "action": "register" },
    { "method": "POST", "path": "/api/auth/login", "action": "login" },
    { "method": "GET", "path": "/api/auth/me", "action": "me" }
  ],
  "resource_limits": {
    "max_memory_mb": 128,
    "max_execution_seconds": 10,
    "max_cpu_percent": 25
  }
}
